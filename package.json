{
  "name": "usshtc107",
  "version": "1.2.1",
  "description": "USTC computing platform SSH proxy client",
  "author": "Enthusjast <enthusjast@outlook.com>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ssh2": "^1.17.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  }
}
